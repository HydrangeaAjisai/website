---
import Navbar from '../components/Navbar.astro';
import Live2D from '../components/Live2D.astro';
---

<!doctype html>
<html lang="zh-CN">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<link rel="icon" href="/favicon.ico" />
		<meta name="generator" content={Astro.generator} />
		<title> Ajisai 的网站 </title>
		<slot name="head" />
	</head>
	<body>
		<div class="wrapper">
			<Navbar />
			<slot />
			<Live2D />
		</div>
	</body>
</html>

<style>
	:root {
		--bg-page: #1a1a2e;
		--bg-card: #333344;
		--text-primary: #e0e0e0;
		--text-heading: #f0f0f0;
		--text-secondary: #a0a0a0;
		--text-muted: #777;
		--text-nav: #aaa;
		--border-color: #444;
		--border-light: #333;
		--link-hover: #66b3ff;
	}

	[data-theme="light"] {
		--bg-page: #f9f9f9;
		--bg-card: #e0e0e0;
		--text-primary: #333;
		--text-heading: #222;
		--text-secondary: #666;
		--text-muted: #888;
		--text-nav: #555;
		--border-color: #ddd;
		--border-light: #eee;
		--link-hover: #0066cc;
	}

	html,
	body {
		margin: 0;
		width: 100%;
		min-height: 100%;
		font-family: system-ui, -apple-system, 'Segoe UI', Roboto, 'Helvetica Neue', Arial, sans-serif;
		line-height: 1.6;
		color: var(--text-primary);
		background: var(--bg-page);
		transition: color 1s, background 1s;
	}

	.wrapper {
		width: 100%;
		max-width: 800px;
		padding: 0 1.5rem;
		box-sizing: border-box;
		margin: 0 auto;
	}

	.katex {
		color: var(--text-primary);
	}

	.katex-display {
		margin: 1rem 0;
		overflow-x: auto;
	}
  	blockquote {
    	background-color: #04040433;
    	padding: 8px 12px;
    	border-radius: 4px;
    	border-left: 3px solid #666;
    	margin: 1em 0;
    	font-size: 0.95em;
  	}

  	blockquote p {
    	margin: 0;
  	}
</style>
