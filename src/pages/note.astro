---
import Layout from '../layouts/Layout.astro';
---

<Layout>
	<header>
		<h1>课堂笔记</h1>
		<p>这里记录我学过的知识和课堂笔记。</p>
	</header>

	<main>
		<section>
			<h2>数学</h2>
			<p>笔记内容占位，以后可以替换成真正的笔记。</p>
		</section>

		<section>
			<h2>计算机</h2>
			<p>笔记内容占位，以后可以替换成真正的笔记。</p>
		</section>
	</main>

	<footer>
		<p><a href="/">← 返回首页</a></p>
	</footer>
</Layout>

<style>
	header {
		margin-top: 4rem;
		margin-bottom: 3rem;
	}

	h1 {
		font-size: 2.5rem;
		margin: 0 0 0.5rem;
		color: #222;
	}

	header p {
		font-size: 1.2rem;
		color: #666;
		margin: 0;
	}

	section {
		margin-bottom: 2.5rem;
	}

	h2 {
		font-size: 1.5rem;
		margin: 0 0 0.75rem;
		color: #444;
		border-bottom: 2px solid #ddd;
		padding-bottom: 0.5rem;
	}

	p {
		margin: 0 0 1rem;
	}

	footer {
		margin-top: 4rem;
		padding-top: 2rem;
		border-top: 1px solid #ddd;
	}

	footer a {
		color: #555;
		text-decoration: none;
	}

	footer a:hover {
		text-decoration: underline;
	}
</style>