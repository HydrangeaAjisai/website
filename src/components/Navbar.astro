---
const currentPath = Astro.url.pathname;
---

<nav>
	<a href="/" class="brand">Ajisai</a>
	<ul>
		<li><a href="/note" class={currentPath === '/note' ? 'active' : ''}>笔记</a></li>
		<li><a href="/blog" class={currentPath === '/blog' ? 'active' : ''}>博客</a></li>
		<li><a href="/artworks" class={currentPath === '/artworks' ? 'active' : ''}>照片</a></li>
	</ul>
</nav>

<style>
	nav {
		display: flex;
		align-items: center;
		justify-content: space-between;
		padding: 1rem 0;
		border-bottom: 1px solid #ddd;
		margin-bottom: 2rem;
	}

	.brand {
		font-size: 1.25rem;
		font-weight: bold;
		color: #222;
		text-decoration: none;
	}

	.brand:hover {
		color: #0066cc;
	}

	ul {
		display: flex;
		list-style: none;
		gap: 1.5rem;
		margin: 0;
		padding: 0;
	}

	nav a {
		color: #555;
		text-decoration: none;
		font-size: 0.95rem;
		transition: color 0.2s;
	}

	nav a:hover {
		color: #0066cc;
	}

	.active {
		color: #0066cc !important;
		font-weight: 500;
	}
</style>